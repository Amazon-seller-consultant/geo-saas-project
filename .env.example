# PostgreSQL connection string used by SQLAlchemy/Alembic
# In production, use the connection string provided by your managed database
# (e.g. Render, Railway, Supabase, Neon).
DATABASE_URL=postgresql+psycopg2://geo_user:geo_password@localhost:5432/geo_saas

# Redis connection string used for caching rank-check results
REDIS_URL=redis://localhost:6379/0

# OpenAI API key (used for the AI Rank Tracker's web-search queries and the
# Content Auditor). Required for those features to work.
OPENAI_API_KEY=sk-your-key-here

# OpenAI model used for rank-tracking queries
OPENAI_MODEL=gpt-4.1

# Number of hours before a keyword is eligible to be re-checked
RANK_CHECK_CACHE_HOURS=24

# JWT auth settings
# IMPORTANT: generate a long random string for production, e.g. with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Comma-separated list of frontend URLs allowed to call this API.
# In production, set this to your deployed frontend's URL(s), e.g.
#   CORS_ORIGINS=https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000
